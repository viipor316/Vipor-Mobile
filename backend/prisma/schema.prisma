// VIPOR Service — production schema. Multi-tenant: every business row carries
// tenantId and queries are scoped to the caller's tenant.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// TENANCY & BILLING
// ---------------------------------------------------------------------------
model Tenant {
  id        String       @id @default(cuid())
  slug      String       @unique
  name      String
  status    TenantStatus @default(incomplete) // gated until a subscription is active
  tier      String       @default("starter")  // starter | pro | fleet
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  createdAt DateTime     @default(now())

  branding        TenantBranding?
  users           User[]
  customers       Customer[]
  vehicles        Vehicle[]
  serviceRequests ServiceRequest[]
  quotes          Quote[]
  jobs            Job[]
}

enum TenantStatus {
  incomplete // signed up, not yet paid
  trialing
  active
  past_due   // payment failed -> access gated
  canceled
}

model TenantBranding {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl      String?
  primaryColor String   @default("#1b2434")
  locales      String[] @default(["en", "fr"])
}

// ---------------------------------------------------------------------------
// USERS (role-based: customer / technician / admin)
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  name         String
  role         Role     @default(customer)
  passwordHash String
  createdAt    DateTime @default(now())

  customer Customer?

  @@unique([tenantId, email])
  @@index([tenantId])
}

enum Role {
  customer
  technician
  admin
}

model Customer {
  id       String    @id @default(cuid())
  tenantId String
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone    String?
  vehicles Vehicle[]

  @@index([tenantId])
}

model Vehicle {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  make       String
  model      String
  year       Int
  vin        String?

  serviceRequests ServiceRequest[]

  @@index([tenantId])
}

// ---------------------------------------------------------------------------
// CORE FLOW: request -> quote -> job
// ---------------------------------------------------------------------------
model ServiceRequest {
  id          String        @id @default(cuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vehicleId   String
  vehicle     Vehicle       @relation(fields: [vehicleId], references: [id])
  description String
  photoUrls   String[]      @default([])
  status      RequestStatus @default(submitted)
  createdAt   DateTime      @default(now())

  quote Quote?

  @@index([tenantId])
}

enum RequestStatus {
  submitted
  quoted
  closed
}

model Quote {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestId String         @unique
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  lineItems Json
  markupPct Decimal        @default(0) @db.Decimal(5, 2)
  total     Decimal        @db.Decimal(10, 2)
  pdfUrl    String?
  status    QuoteStatus    @default(draft)
  sentAt    DateTime?
  decidedAt DateTime?
  createdAt DateTime       @default(now())

  job Job?

  @@index([tenantId])
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
}

model Job {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteId      String    @unique
  quote        Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  technicianId String?
  status       JobStatus @default(pending)
  createdAt    DateTime  @default(now())

  locations JobLocation[]

  @@index([tenantId])
  @@index([status])
}

enum JobStatus {
  pending
  en_route
  in_progress
  completed
  canceled
}

model JobLocation {
  id         String   @id @default(cuid())
  tenantId   String
  jobId      String
  job        Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  lat        Float
  lng        Float
  recordedAt DateTime @default(now())

  @@index([jobId])
}
