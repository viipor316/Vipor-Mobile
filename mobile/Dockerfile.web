# VIPOR web app — build the Expo web export and serve it with nginx.
# Deploy on TrueNAS like the backend: build via GHCR, run as a Custom App.

# 1) build the static web bundle
FROM node:22-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install --legacy-peer-deps
COPY . .
# API the web app talks to (override at build time if needed)
ARG EXPO_PUBLIC_API_URL=https://vipor-api.vipor.ca/api
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL
RUN npx expo export --platform web

# 2) serve it
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
# single-page-app fallback so deep links resolve to index.html
RUN printf 'server {\n  listen 80;\n  root /usr/share/nginx/html;\n  location / { try_files $uri $uri/ /index.html; }\n}\n' > /etc/nginx/conf.d/default.conf
EXPOSE 80
